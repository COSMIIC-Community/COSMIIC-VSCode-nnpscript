{
  "name": "nnpscript",
  "displayName": "nnpscript Language Support",
  "description": "Syntax highlighting for .nnpscript files, ported from the Notepad++ UDL definition.",
  "version": "1.0.4",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:COSMIIC-Community/COSMIIC-VSCode-nnpscript.git"
  },
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "nnpscript",
        "aliases": ["nnpscript", "NNP Script"],
        "extensions": [".nnpscript"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nnpscript",
        "scopeName": "source.nnpscript",
        "path": "./syntaxes/nnpscript.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "comment.line.percent.nnpscript",
            "settings": { "foreground": "#6A9955", "fontStyle": "italic" }
          },
          {
            "scope": "storage.type.nnpscript",
            "settings": { "foreground": "#4EC9B0", "fontStyle": "bold" }
          },
          {
            "scope": "keyword.control.mnemonic.nnpscript",
            "settings": { "foreground": "#569CD6", "fontStyle": "bold" }
          },
          {
            "scope": "support.function.log.nnpscript",
            "settings": { "foreground": "#569CD6", "fontStyle": "bold" }
          },
          {
            "scope": "keyword.operator.nnpscript",
            "settings": { "foreground": "#569CD6" }
          },
          {
            "scope": "constant.numeric.nnpscript",
            "settings": { "foreground": "#B5CEA8" }
          },
          {
            "scope": "string.quoted.double.nnpscript",
            "settings": { "foreground": "#C586C0" }
          },
          {
            "scope": "string.other.exclamation.nnpscript",
            "settings": { "foreground": "#FF8000", "fontStyle": "bold" }
          },
          {
            "scope": "meta.block.nnpscript, punctuation.definition.block.begin.nnpscript, punctuation.definition.block.end.nnpscript",
            "settings": { "foreground": "#D670C0", "fontStyle": "italic" }
          },
          {
            "scope": "variable.other.od-index.nnpscript",
            "settings": { "foreground": "#E396DF" }
          }
        ]
      }
    }
  }
}
