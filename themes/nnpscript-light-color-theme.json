{
  "name": "nnpscript Light (NP++ style)",
  "$schema": "vscode://schemas/color-theme",
  "type": "light",
  "colors": {
    "editor.background": "#FFFFFF",
    "editor.foreground": "#000000"
  },
  "tokenColors": [
    {
      "name": "Default text",
      "scope": "source.nnpscript",
      "settings": { "foreground": "#000000" }
    },
    {
      "name": "Line comments  (% ...)  — green, italic  [LINE COMMENTS fgColor=008000 fontStyle=2]",
      "scope": "comment.line.percent.nnpscript",
      "settings": { "foreground": "#008000", "fontStyle": "italic" }
    },
    {
      "name": "Block comments — pink/magenta  [COMMENTS fgColor=FF80FF]",
      "scope": "comment.block.nnpscript",
      "settings": { "foreground": "#FF80FF" }
    },
    {
      "name": "Keywords1 — type/storage words — teal, bold  [KEYWORDS1 fgColor=00A8A8 fontStyle=1]",
      "scope": "storage.type.nnpscript",
      "settings": { "foreground": "#00A8A8", "fontStyle": "bold" }
    },
    {
      "name": "Keywords2 — instruction mnemonics — blue, bold  [KEYWORDS2 fgColor=0000FF fontStyle=1]",
      "scope": "keyword.control.mnemonic.nnpscript",
      "settings": { "foreground": "#0000FF", "fontStyle": "bold" }
    },
    {
      "name": "Keywords3 — log/timelog — blue, bold  [KEYWORDS3 fgColor=0000FF fontStyle=1]",
      "scope": "support.function.log.nnpscript",
      "settings": { "foreground": "#0000FF", "fontStyle": "bold" }
    },
    {
      "name": "Operators — blue  [OPERATORS fgColor=0000FF]",
      "scope": "keyword.operator.nnpscript",
      "settings": { "foreground": "#0000FF" }
    },
    {
      "name": "Numbers — black (default)  [NUMBERS fgColor=000000]",
      "scope": "constant.numeric.nnpscript",
      "settings": { "foreground": "#000000" }
    },
    {
      "name": "Double-quoted strings — purple  [DELIMITERS1 fgColor=8000FF]",
      "scope": "string.quoted.double.nnpscript",
      "settings": { "foreground": "#8000FF" }
    },
    {
      "name": "!-delimited strings — orange, bold  [DELIMITERS3 fgColor=FF8000 fontStyle=1]",
      "scope": "string.other.exclamation.nnpscript",
      "settings": { "foreground": "#FF8000", "fontStyle": "bold" }
    },
    {
      "name": "{ } block content — dark magenta, italic  [DELIMITERS7 fgColor=800040 fontStyle=2]",
      "scope": [
        "meta.block.nnpscript",
        "punctuation.definition.block.begin.nnpscript",
        "punctuation.definition.block.end.nnpscript"
      ],
      "settings": { "foreground": "#800040", "fontStyle": "italic" }
    }
  ]
}
